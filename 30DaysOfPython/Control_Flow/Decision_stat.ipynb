    "#simple while loop\n",
    "\n",
    "n = 0\n",
    "\n",
    "while(n<=10):\n",
    "    print(\"Number is \\t\", n)\n",
    "    n = n + 1\n",
    "\n",
    "print(\"Loop Over\")\n",
    "\n"
